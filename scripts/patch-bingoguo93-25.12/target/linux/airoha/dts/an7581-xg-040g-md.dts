/dts-v1/;

#include <dt-bindings/leds/common.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "an7581-nowifi.dtsi"
#include "an7581-npu-mt7996.dtsi"

/ {
    model = "Nokia Bell XG-040G-MD";
    compatible = "bell,xg-040g-md", "airoha,an7581";

    reserved-memory {
        #address-cells = <2>;
        #size-cells = <2>;
        ranges;

        /* 优化 NPU 内存分配以适配 2GB RAM - 性能优先布局 */
        npu_binary: npu-binary@84000000 {
            no-map;
            reg = <0x0 0x84000000 0x0 0x800000>;
            alignment = <0x100000>;
        };

        qdma0_buf: qdma0-buf@86000000 {
            no-map;
            reg = <0x0 0x86000000 0x0 0x1800000>;
            alignment = <0x100000>;
        };

        qdma1_buf: qdma1-buf@87800000 {
            no-map;
            reg = <0x0 0x87800000 0x0 0xc00000>;
            alignment = <0x100000>;
        };

        npu_pkt: npu-pkt@88400000 {
            no-map;
            reg = <0x0 0x88400000 0x0 0x800000>;
            alignment = <0x100000>;
        };

        npu_txpkt: npu-txpkt@88c00000 {
            no-map;
            reg = <0x0 0x88c00000 0x0 0x800000>;
            alignment = <0x100000>;
        };

        npu_txbufid: npu-txbufid@89400000 {
            no-map;
            reg = <0x0 0x89400000 0x0 0x6800>;
            alignment = <0x1000>;
        };
    };

    efuse-banks {
        compatible = "airoha,an7581-efuses";
        #address-cells = <0x01>;
        #size-cells = <0x00>;

        bank@0 {
            reg = <0x00>;
        };

        bank@1 {
            reg = <0x01>;
        };
    };

    aliases {
        serial0 = &uart1;
    };

    chosen {
        bootargs = "console=ttyS0,115200n8 earlycon";
        stdout-path = "serial0:115200n8";
        bootargs-append = " ubi.mtd=rootfs,2048 rootfstype=squashfs ubi.block=0,rootfs ro init=/etc/preinit irqaffinity=0xf cpufreq.default_governor=performance skew_tick=1 nohz=on nohz_full=1-3 rcu_nocbs=1-3";
    };

    memory@80000000 {
        device_type = "memory";
        reg = <0x0 0x80000000 0x0 0x80000000>;
    };

	leds {
		compatible = "gpio-leds";

		led-0 {
			label = "pwr";
			color = <0x01>;
			function = "power";
			gpios = <0x24 0x11 0x01>;
			default-state = "on";
		};

		led-2 {
			label = "pon";
			color = <0x02>;
			function = "status";
			gpios = <0x24 0x13 0x01>;
			default-state = "off";
		};

		led-3 {
			label = "internet";
			color = <0x02>;
			function = "status";
			gpios = <0x24 0x14 0x01>;
			default-state = "on";
		};
	};
};

&en7581_pinctrl {
    gpio-ranges = <&en7581_pinctrl 0 13 47>;

    mdio_pins: mdio-pins {
        mux {
            function = "mdio";
            groups = "mdio";
        };

        conf {
            pins = "gpio2";
            output-high;
        };
    };

    pcie0_rst_pins: pcie0-rst-pins {
        conf {
            pins = "pcie_reset0";
            drive-open-drain = <1>;
        };
    };

    pcie1_rst_pins: pcie1-rst-pins {
        conf {
            pins = "pcie_reset1";
            drive-open-drain = <1>;
        };
    };

    gswp1_led0_pins: gswp1-led0-pins {
        mux {
            function = "phy1_led0";
            pins = "gpio33";
        };
    };

    gswp2_led0_pins: gswp2-led0-pins {
        mux {
            function = "phy2_led0";
            pins = "gpio34";
        };
    };

    gswp3_led0_pins: gswp3-led0-pins {
        mux {
            function = "phy3_led0";
            pins = "gpio35";
        };
    };

    gswp4_led0_pins: gswp4-led0-pins {
        mux {
            function = "phy4_led0";
            pins = "gpio42";
        };
    };
};

&snfi {
	status = "okay";
	spi-max-frequency = <52000000>;
};


&spi_nand {
	#address-cells = <1>;
	#size-cells = <1>;
        partitions {
        compatible = "fixed-partitions";
		    #address-cells = <1>;
		    #size-cells = <1>;

            partition@0 {
                label = "bootloader";
                reg = <0x0  0x00080000>;
                read-only;
            };

            partition@80000  {
                label = "env";
                reg = <0x00080000 0x00080000>;
            };

            partition@100000 {
                label = "ubi";
                reg = <0x00100000  0x00>;
		ubi-reserved-pebs = <40>;
		};
     };
};

&usb0 {
	status = "okay";
	maximum-speed = "super-speed";
};

&usb1 {
	status = "okay";
	mediatek,u3p-dis-msk = <0x1>;
	phys = <&usb1_phy PHY_TYPE_USB2>;
	maximum-speed = "high-speed";
};

&i2c0 {
    status = "okay";
};

&npu {
	status = "okay";
};

&eth {
	status = "okay";
	local-mac-address = [00 0c 43 26 60 00];
	dma-coherent;
};

&gdm1{
	status = "okay";
	local-mac-address = [00 0c 43 26 60 01];
	tx-queues = <4>;
	rx-queues = <4>;
};

&gdm4{
	status = "okay";
	phy-handle = <&phy15>;
	phy-mode = "2500base-x";
	label = "wan";
	local-mac-address = [00 0c 43 26 60 02];
	tx-queues = <4>;
	rx-queues = <4>;
};

&switch {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&mdio_pins>;
	local-mac-address = [00 0c 43 26 60 03];

	mdio {

		phy15: ethernet-phy@f {
			/* EN8811H PHY ID */
			compatible = "ethernet-phy-id03a2.a411";
			reg = <15>;

			interrupt-parent = <&gic>;
			reset-gpios = <&en7581_pinctrl 31 GPIO_ACTIVE_LOW>;
			reset-assert-us = <5000>;
			reset-deassert-us = <1000000>;
			phy-mode = "2500base-x";
			max-speed = <2500>;
		};
	};

};

&gsw_port2{
	status = "okay";
	label = "lan2";
};

&gsw_phy2 {

	pinctrl-names = "gbe-led";
	pinctrl-0 = <&gswp2_led0_pins>;
	status = "okay";
};

&gsw_phy2_led0 {
	status = "okay";
	active-low;
};

&gsw_port3{
	status = "okay";
	label = "lan3";
};

&gsw_phy3 {

	pinctrl-names = "gbe-led";
	pinctrl-0 = <&gswp3_led0_pins>;
	status = "okay";
};

&gsw_phy3_led0 {
	status = "okay";
	active-low;
};

&gsw_port4{
	status = "okay";
	label = "lan4";
};

&gsw_phy4 {

	pinctrl-names = "gbe-led";
	pinctrl-0 = <&gswp4_led0_pins>;
	status = "okay";
};

&gsw_phy4_led0 {
	color = <LED_COLOR_ID_GREEN>;
	function = LED_FUNCTION_WAN;
	default-state = "keep";
	status = "okay";
	active-low;
};

&afe {
	status = "disabled";
};

&npu {
	status = "okay";
	/* 优化 NPU 性能 */
	memory-region = <&npu_binary>, <&npu_pkt>, <&npu_txpkt>, <&npu_txbufid>;
	memory-region-names = "binary", "pkt", "tx-pkt", "tx-bufid";
	dma-coherent;
	firmware-name = "airoha/en7581_MT7996_npu_rv32.bin",
	                "airoha/en7581_MT7996_npu_data.bin";
};
